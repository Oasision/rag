# 澶嶅埗涓洪」鐩牴鐩綍 `.env` 鍚庡啀濉啓鐪熷疄鍊笺€?# 搴旂敤鍚姩鏃朵細鑷姩璇诲彇璇ユ枃浠讹紝閫傜敤浜?IDE 鐩存帴璺?main 鍜?`mvn spring-boot:run`銆?
# Spring profile锛岄€氬父鏈湴浣跨敤 dev
SPRING_PROFILES_ACTIVE=dev
APP_TIMEZONE=Asia/Shanghai

# 鏈嶅姟鐩戝惉绔彛
SERVER_PORT=8081

# MySQL锛屽簱鍚嶅缓璁繚鎸佷负 RAG
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/RAG?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Kafka锛宼opic 浼氬湪搴旂敤鍚姩鏃惰嚜鍔ㄥ垱寤猴紝鏃犻渶鍐嶆墜宸ユ墽琛?kafka-topics.sh
SPRING_KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092
SPRING_KAFKA_TOPIC_PARTITIONS=1
SPRING_KAFKA_TOPIC_REPLICATION_FACTOR=1

# MinIO锛屽璞″瓨鍌ㄧ敤浜庢枃浠朵笂浼犱笌瑙ｆ瀽閾捐矾
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=uploads

# Elasticsearch銆?# 鏈湴鑷鍚嶈瘉涔﹀彲鐢?https + trust-all=true锛?# 鐢熶骇鐜鍔″繀鏀逛负 trust-all=false锛屽苟纭繚 JVM 淇′换璇ヨ瘉涔﹂摼銆?ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_SCHEME=https
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=change-me
ELASTICSEARCH_INSECURE_TRUST_ALL_CERTIFICATES=true

# JWT_SECRET_KEY 蹇呴』鏄?Base64 瀛楃涓诧紝鍙敤 `openssl rand -base64 32` 鐢熸垚
JWT_SECRET_KEY=XeJw0yUoFDJWSNbWYFVEIXGfO8XgHrQLrIkKci5J9eA=

# 棣栨鍚姩鍒涘缓绠＄悊鍛樻椂涓存椂鎵撳紑锛屽垱寤烘垚鍔熷悗搴旀敼鍥?false
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
ADMIN_BOOTSTRAP_PRIMARY_ORG=default
ADMIN_BOOTSTRAP_ORG_TAGS=default,admin

# 娉ㄥ唽妯″紡锛歄PEN / INVITE_ONLY / CLOSED
APP_AUTH_REGISTRATION_MODE=INVITE_ONLY
APP_AUTH_INVITE_REQUIRED=true

# 鍓嶇鏉ユ簮鐧藉悕鍗曪紝澶氫釜鍩熷悕鐢ㄩ€楀彿鍒嗛殧
SECURITY_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# LLM 涓?Embedding 鎻愪緵鏂?DEEPSEEK_API_URL=https://api.deepseek.com/v1
DEEPSEEK_API_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_MODEL=text-embedding-v4
EMBEDDING_API_KEY=
VISION_EMBEDDING_API_URL=https://dashscope.aliyuncs.com
VISION_EMBEDDING_API_MODEL=multimodal-embedding-v1
VISION_EMBEDDING_API_KEY=
VISION_EMBEDDING_DIMENSION=1024
MULTIMODAL_LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MULTIMODAL_LLM_API_MODEL=qwen-vl-plus
MULTIMODAL_LLM_API_KEY=

# 鏃ュ織绛夌骇锛屾帓闅滄椂鍙复鏃舵敼涓?DEBUG
LOG_LEVEL_APP=INFO

# 鍓嶇閮ㄧ讲
DEPLOY_SERVER_HOST=
DEPLOY_SERVER_USER=root
DEPLOY_SERVER_KEY=/absolute/path/to/paicoding.pem
DEPLOY_TARGET_DIR=/home/www/RAG-Front
DEPLOY_HEALTHCHECK_URL=https://smart.paicoding.com
DEPLOY_HEALTHCHECK_TIMEOUT=15

# 寰俊鏀粯鐩稿叧閰嶇疆
WX_PAY_ENABLE=false
WX_PAY_APP_ID=
WX_PAY_MERCHANT_ID=
WX_PAY_PRIVATE_KEY=
WX_PAY_MERCHANT_SERIAL_NUMBER=
WX_PAY_API_V3_KEY=
WX_PAY_NOTIFY_URL=https://smart.paicoding.com/api/v1/recharge/pay-callback
WX_PAY_REFUND_NOTIFY_URL=https://smart.paicoding.com/api/v1/recharge/refund-callback
